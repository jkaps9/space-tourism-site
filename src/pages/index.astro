---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Home";
---

<BaseLayout pageTitle={pageTitle}>
  <section class="hero">
    <div class="container">
      <div class="text">
        <span class="topper">So, you want to travel to</span>
        <h1>Space</h1>
        <p>
          Let’s face it; if you want to go to space, you might as well genuinely
          go to outer space and not hover kind of on the edge of it. Well sit
          back, and relax because we’ll give you a truly out of this world
          experience!
        </p>
      </div>
      <div class="button">
        <a
          href="/destination/"
          class="btn btn--solid"
        >
          EXPLORE
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .container {
    flex: 1;
    display: grid;
    text-align: center;
  }

  .text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .btn {
    margin-top: auto;
  }
</style>
