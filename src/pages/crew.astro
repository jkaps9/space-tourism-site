---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Crew";
const smallImageSrc = "/src/assets/images/background-home-mobile.jpg";
const mediumImageSrc = "/src/assets/images/background-home-tablet.jpg";
const largeImageSrc = "/src/assets/images/background-home-desktop.jpg";
---

<BaseLayout
  pageTitle={pageTitle}
  smallImageSrc={smallImageSrc}
  mediumImageSrc={mediumImageSrc}
  largeImageSrc={largeImageSrc}
>
  <section class="crew">
    <div class="container">
      <h2 class="page-title">
        <span>02</span>MEET YOUR CREW
      </h2>
    </div>
  </section>
</BaseLayout>
